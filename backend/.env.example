NODE_ENV=development
HOST=0.0.0.0
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-letters-numbers-underscore-or-dash
TELEGRAM_INIT_DATA_TTL_SECONDS=86400
BACKEND_PUBLIC_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-server-only-secret-key
DIAGNOSTICS_SECRET=replace-with-a-random-secret-of-at-least-32-characters
POCKET_COLLECTOR_ENABLED=true
# Full outgoing 42["auth",{...}] packet from a Pocket Demo session. Server-only secret.
POCKET_AUTH_PACKET=
POCKET_DEMO_REGION=EU
# Only explicitly prepared assets receive live ticks. Hard maximum: 5.
POCKET_MAX_ACTIVE_ASSETS=3
POCKET_STALE_AFTER_MS=15000
